@model KeysIndexViewModel
@{
    ViewData["Title"] = "Danh sách key";
}

<div class="stats-grid">
    <div class="stat-card"><span>Tổng key</span><strong>@ViewBag.Total</strong></div>
    <div class="stat-card"><span>Đang active</span><strong>@ViewBag.Active</strong></div>
    <div class="stat-card"><span>Đang bị khóa</span><strong>@ViewBag.Blocked</strong></div>
    <div class="stat-card"><span>Đã bind máy</span><strong>@ViewBag.Bound</strong></div>
</div>

<section class="panel">
    <form method="get" class="filter-grid">
        <div>
            <label>Tìm kiếm</label>
            <input type="text" name="Search" value="@Model.Filter.Search" placeholder="key, device id, product" />
        </div>
        <div>
            <label>Trạng thái</label>
            <select name="Status">
                <option value="">Tất cả</option>
                @foreach (var status in Enum.GetValues<LicenseStatus>())
                {
                    if (Model.Filter.Status == status)
                    {
                        <option value="@status" selected>@status</option>
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
        </div>
        <div>
            <label>Bind máy</label>
            <select name="BoundOnly">
                <option value="">Tất cả</option>
                @if (Model.Filter.BoundOnly == true)
                {
                    <option value="true" selected>Chỉ key đã bind</option>
                }
                else
                {
                    <option value="true">Chỉ key đã bind</option>
                }
            </select>
        </div>
        <div class="actions-bottom">
            <button class="btn btn-primary" type="submit">Lọc</button>
            <a class="btn btn-secondary" asp-action="Index">Xóa lọc</a>
        </div>
    </form>
</section>

<section class="panel">
    <div class="panel-head">
        <h2>Danh sách key</h2>
        <a class="btn btn-primary" asp-action="Create">+ Tạo key</a>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Key</th>
                    <th>Sản phẩm</th>
                    <th>Thiết bị</th>
                    <th>Trạng thái</th>
                    <th>Hết hạn</th>
                    <th>Kích hoạt</th>
                    <th>Tạo lúc</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Items.Any())
            {
                <tr><td colspan="9" class="empty">Chưa có dữ liệu.</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <div class="key-cell">@item.KeyValue</div>
                            @if (!string.IsNullOrWhiteSpace(item.Note))
                            {
                                <div class="note-text">@item.Note</div>
                            }
                        </td>
                        <td>@item.ProductCode</td>
                        <td>@(item.DeviceId ?? "-")</td>
                        <td>
                            <span class="badge @(item.Status == LicenseStatus.Active ? "green" : item.Status == LicenseStatus.Blocked ? "red" : "gray")">
                                @item.Status
                            </span>
                            @if (item.IsExpired)
                            {
                                <span class="badge red">Expired</span>
                            }
                        </td>
                        <td>@(item.ExpireAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Không hạn")</td>
                        <td>@item.ActivationCount</td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="row-actions">
                                <a class="btn btn-secondary small" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                                <form asp-action="ResetDevice" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-warning small">Reset máy</button>
                                </form>
                                <form asp-action="ToggleBlock" asp-route-id="@item.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-secondary small">@(item.Status == LicenseStatus.Blocked ? "Mở khóa" : "Khóa")</button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa key này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger small">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
